PORT=4000

# Option A: single connection string (takes priority if set)
DATABASE_URL=mysql://portfolio_admin:password@portfolio-db.xxxxxx.ap-northeast-2.rds.amazonaws.com:3306/webportfolio

# Option B: discrete fields (used if DATABASE_URL is not set)
MYSQL_HOST=portfolio-db.xxxxxx.ap-northeast-2.rds.amazonaws.com
MYSQL_PORT=3306
MYSQL_USER=portfolio_admin
MYSQL_PASSWORD=
MYSQL_DATABASE=webportfolio

# In production, set this to your CloudFront/custom-domain frontend origin.
ALLOWED_ORIGINS=https://www.your-domain.com,http://localhost:5173

# Discord webhook URL for new-contact-message notifications (optional)
DISCORD_WEBHOOK_URL=

# NPC AI 챗봇(Gemini) 설정 — https://aistudio.google.com/apikey 에서 발급
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# /admin dashboard API token. Use a long random value in production.
ADMIN_API_TOKEN=
