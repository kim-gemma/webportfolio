PORT=4000

# Option A: single connection string (takes priority if set)
DATABASE_URL=mysql://user:password@localhost:3306/webportfolio

# Option B: discrete fields (used if DATABASE_URL is not set)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=webportfolio

# In production, set this to your deployed frontend origin, e.g. https://my-portfolio.vercel.app
ALLOWED_ORIGINS=http://localhost:5173

# Discord webhook URL for new-contact-message notifications (optional)
DISCORD_WEBHOOK_URL=